# ── Required for correct canonical URLs and sitemap ─────────────────────────
NEXT_PUBLIC_SITE_URL="https://subhambhattacharya.com"

# ── Contact form ────────────────────────────────────────────────────────────
# Without these the form still renders and validates, but on submit it tells
# the visitor to email directly and offers a copy-to-clipboard button. It never
# silently swallows a message.
#
# Setup (about five minutes, free tier):
#   1. Create an account at https://resend.com
#   2. Verify a domain, or use Resend's onboarding sender for testing
#   3. Create an API key and paste it below
RESEND_API_KEY=""
CONTACT_TO_EMAIL="subham.bh@icloud.com"
CONTACT_FROM_EMAIL="site@subhambhattacharya.com"

# ── GitHub (optional) ───────────────────────────────────────────────────────
# Fine-grained PAT with ZERO scopes — public read only.
# Without it the site falls back to the committed snapshot in src/lib/github.ts.
# https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=""
